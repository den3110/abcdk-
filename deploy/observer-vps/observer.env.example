NODE_ENV=production
OBSERVER_PORT=8787
OBSERVER_BIND_HOST=0.0.0.0
OBSERVER_API_KEY=replace-with-a-long-random-secret
OBSERVER_READ_API_KEY=replace-with-a-different-read-only-secret
