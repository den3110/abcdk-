[Unit]
Description=PickleTour Go RTMP Relay
After=network.target
Wants=network.target

[Service]
Type=simple
WorkingDirectory=/var/www/pickletour
EnvironmentFile=/var/www/pickletour/.env
ExecStart=/var/www/pickletour/backend-go/bin/pickletour-relay-rtmp
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
