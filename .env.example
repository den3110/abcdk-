R2_RECORDINGS_TARGETS_JSON=[{"id":"r2-01","label":"R2 01","endpoint":"https://<account-01>.r2.cloudflarestorage.com","accessKeyId":"<key-01>","secretAccessKey":"<secret-01>","bucketName":"recordings","capacityBytes":10737418240,"publicBaseUrl":"","enabled":true},{"id":"r2-02","label":"R2 02","endpoint":"https://<account-02>.r2.cloudflarestorage.com","accessKeyId":"<key-02>","secretAccessKey":"<secret-02>","bucketName":"recordings","capacityBytes":10737418240,"publicBaseUrl":"","enabled":false},{"id":"r2-03","label":"R2 03","endpoint":"https://<account-03>.r2.cloudflarestorage.com","accessKeyId":"<key-03>","secretAccessKey":"<secret-03>","bucketName":"recordings","capacityBytes":10737418240,"publicBaseUrl":"","enabled":false},{"id":"r2-04","label":"R2 04","endpoint":"https://<account-04>.r2.cloudflarestorage.com","accessKeyId":"<key-04>","secretAccessKey":"<secret-04>","bucketName":"recordings","capacityBytes":10737418240,"publicBaseUrl":"","enabled":false},{"id":"r2-05","label":"R2 05","endpoint":"https://<account-05>.r2.cloudflarestorage.com","accessKeyId":"<key-05>","secretAccessKey":"<secret-05>","bucketName":"recordings","capacityBytes":10737418240,"publicBaseUrl":"","enabled":false},{"id":"r2-06","label":"R2 06","endpoint":"https://<account-06>.r2.cloudflarestorage.com","accessKeyId":"<key-06>","secretAccessKey":"<secret-06>","bucketName":"recordings","capacityBytes":10737418240,"publicBaseUrl":"","enabled":false},{"id":"r2-07","label":"R2 07","endpoint":"https://<account-07>.r2.cloudflarestorage.com","accessKeyId":"<key-07>","secretAccessKey":"<secret-07>","bucketName":"recordings","capacityBytes":10737418240,"publicBaseUrl":"","enabled":false},{"id":"r2-08","label":"R2 08","endpoint":"https://<account-08>.r2.cloudflarestorage.com","accessKeyId":"<key-08>","secretAccessKey":"<secret-08>","bucketName":"recordings","capacityBytes":10737418240,"publicBaseUrl":"","enabled":false},{"id":"r2-09","label":"R2 09","endpoint":"https://<account-09>.r2.cloudflarestorage.com","accessKeyId":"<key-09>","secretAccessKey":"<secret-09>","bucketName":"recordings","capacityBytes":10737418240,"publicBaseUrl":"","enabled":false},{"id":"r2-10","label":"R2 10","endpoint":"https://<account-10>.r2.cloudflarestorage.com","accessKeyId":"<key-10>","secretAccessKey":"<secret-10>","bucketName":"recordings","capacityBytes":10737418240,"publicBaseUrl":"","enabled":false}]

# Legacy single-target fallback (chi dung khi khong can multi-target)
# R2_RECORDINGS_ENDPOINT=https://<account>.r2.cloudflarestorage.com
# R2_RECORDINGS_ACCESS_KEY_ID=<access-key>
# R2_RECORDINGS_SECRET_ACCESS_KEY=<secret-key>
# R2_RECORDINGS_BUCKET_NAME=recordings

# Single-server peak runtime (4 core / 8GB)
ES_ENABLED=false
LIVE_RECORDING_EXPORT_WINDOW_ENABLED=true
LIVE_RECORDING_EXPORT_WINDOW_TZ=Asia/Saigon
LIVE_RECORDING_EXPORT_WINDOW_START=00:00
LIVE_RECORDING_EXPORT_WINDOW_END=06:00
LIVE_RECORDING_FFMPEG_THREADS=1
LIVE_APP_COURT_RUNTIME_CACHE_TTL_MS=1500
LIVE_APP_MATCH_RUNTIME_CACHE_TTL_MS=2000
LIVE_APP_COURT_RUNTIME_WAIT_POLL_MS=5000
LIVE_APP_COURT_RUNTIME_STEADY_POLL_MS=10000
PEAK_RUNTIME_METRICS_WINDOW_MS=300000
PEAK_RUNTIME_METRICS_MAX_SAMPLES_PER_ENDPOINT=1500
