# Single-server peak runtime (4 core / 8GB)
ES_ENABLED=false
LIVE_RECORDING_EXPORT_WINDOW_ENABLED=true
LIVE_RECORDING_EXPORT_WINDOW_TZ=Asia/Saigon
LIVE_RECORDING_EXPORT_WINDOW_START=00:00
LIVE_RECORDING_EXPORT_WINDOW_END=06:00
LIVE_RECORDING_FFMPEG_THREADS=1
# Optional fallback if System Settings has no Script base URL
LIVE_RECORDING_AI_SCRIPT_BASE_URL=
LIVE_RECORDING_AI_SCRIPT_API_KEY=
LIVE_RECORDING_AI_SCRIPT_TIMEOUT_MS=120000
# Optional fallback if System Settings has no Script model
LIVE_RECORDING_AI_SCRIPT_MODEL=
LIVE_RECORDING_AI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
LIVE_RECORDING_AI_SCENE_THRESHOLD=0.18
LIVE_RECORDING_AI_SCENE_MIN_GAP_SECONDS=6
# Optional fallback if System Settings has no TTS base URL
# Leave blank when using the built-in local adapter at /api/ai-tts/v1
LIVE_RECORDING_AI_TTS_BASE_URL=
# Optional. Not required when using the built-in local adapter.
LIVE_RECORDING_AI_TTS_API_KEY=
LIVE_RECORDING_AI_TTS_TIMEOUT_MS=120000
# Optional fallback if System Settings has no TTS model
LIVE_RECORDING_AI_TTS_MODEL=gpt-4o-mini-tts
LIVE_RECORDING_AI_VOICE_VI_MALE=alloy
LIVE_RECORDING_AI_VOICE_VI_FEMALE=nova
LIVE_RECORDING_AI_VOICE_EN_MALE=alloy
LIVE_RECORDING_AI_VOICE_EN_FEMALE=nova
LIVE_RECORDING_AI_COMMENTARY_WORKER_TICK_MS=10000
LIVE_RECORDING_AI_COMMENTARY_STALE_MS=2700000
LIVE_APP_COURT_RUNTIME_CACHE_TTL_MS=1500
LIVE_APP_MATCH_RUNTIME_CACHE_TTL_MS=2000
LIVE_APP_COURT_RUNTIME_WAIT_POLL_MS=5000
LIVE_APP_COURT_RUNTIME_STEADY_POLL_MS=10000
PEAK_RUNTIME_METRICS_WINDOW_MS=300000
PEAK_RUNTIME_METRICS_MAX_SAMPLES_PER_ENDPOINT=1500
