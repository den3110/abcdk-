TELEGRAM_CHAT_CRASH_ID=
TELEGRAM_CHAT_SENTRY_ID=
SENTRY_WEBHOOK_TOKEN=

# backend-go transition
BACKEND_GO_URL=http://127.0.0.1:8005
BACKEND_GO_PORT=8005
BACKEND_GO_RTMP_PORT=5002
BACKEND_GO_SCHEDULER_PORT=8010
BACKEND_GO_RECORDING_EXPORT_PORT=8011
BACKEND_GO_AI_COMMENTARY_PORT=8012
BACKEND_GO_WORKER_GENERAL_PORT=8013
BACKEND_GO_SERVICE_PREFIX=pickletour
# Optional when Mongo URI does not include a database name
MONGO_DB_NAME=
REDIS_URL=redis://127.0.0.1:6379/0
# Optional overrides for backend-go local runtime
PROJECT_ROOT=
UPLOADS_DIR=
# Optional dedicated Mongo URI for backend-go integration tests
BACKEND_GO_TEST_MONGO_URI=
GRAPHQL_DEPRECATION_MODE=audit

# Pikora chatbot - dedicated model/proxy config
# If left blank, Pikora will fall back to:
#   PIKORA_BASE_URL      -> CLIPROXY_BASE_URL
#   PIKORA_API_KEY       -> CLIPROXY_API_KEY -> OPENAI_API_KEY
#   PIKORA_MODEL         -> BOT_MODEL -> deepseek-chat
#   PIKORA_REASONER_MODEL -> BOT_REASONER_MODEL -> deepseek-reasoner
#   PIKORA_PROXY_TIMEOUT_MS -> BOT_PROXY_TIMEOUT_MS -> 45000
PIKORA_BASE_URL=
PIKORA_API_KEY=
PIKORA_MODEL=deepseek-chat
PIKORA_REASONER_MODEL=deepseek-reasoner
PIKORA_PROXY_TIMEOUT_MS=45000

# AI import via CatGPT-Gateway
AI_IMPORT_PROVIDER=catgpt
CATGPT_GATEWAY_BASE_URL=http://localhost:8000/v1
CATGPT_GATEWAY_API_TOKEN=replace-with-your-gateway-token
CATGPT_GATEWAY_MODEL=catgpt-browser
CATGPT_GATEWAY_TIMEOUT_MS=960000

# SEO News image generation via dedicated pplx2api route
SEO_NEWS_IMAGE_GENERATION_URL=http://localhost:8080/v1/images/generations
SEO_NEWS_IMAGE_GENERATION_API_KEY=replace-with-your-image-generation-key
SEO_NEWS_IMAGE_SIZE=1792x1024
SEO_NEWS_IMAGE_QUALITY=hd
SEO_NEWS_IMAGE_STYLE=natural
SEO_NEWS_IMAGE_GENERATION_TIMEOUT_MS=180000

# SEO News evergreen article generation gateway
# Example base URL: http://localhost:8080/v1
SEO_NEWS_ARTICLE_GENERATION_BASE_URL=
SEO_NEWS_ARTICLE_GENERATION_API_KEY=
SEO_NEWS_ARTICLE_GENERATION_TIMEOUT_MS=120000

# Optional cleanup endpoint for local gateway source files
# Example: http://localhost:8080/v1
SEO_NEWS_IMAGE_GATEWAY_BASE_URL=
SEO_NEWS_IMAGE_GATEWAY_API_KEY=

# Public multi-source live playback
# Mac dinh de false cho den khi da map publicBaseUrl rieng theo tung r2TargetId
# va da cau hinh CDN/edge that su xem duoc.
LIVE_MULTI_SOURCE_ENABLED=false
LIVE_SERVER2_DELAY_SECONDS=60
# Fallback chung. Neu dung nhieu R2 target/account, nen de trong va map trong admin.
LIVE_RECORDING_PUBLIC_CDN_BASE_URL=
LIVE_SERVER2_MANIFEST_NAME=live-manifest.json

