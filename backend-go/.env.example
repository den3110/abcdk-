BACKEND_GO_PORT=8005
BACKEND_GO_URL=http://127.0.0.1:8005
BACKEND_GO_RTMP_PORT=5002
BACKEND_GO_SCHEDULER_PORT=8010
BACKEND_GO_RECORDING_EXPORT_PORT=8011
BACKEND_GO_AI_COMMENTARY_PORT=8012
BACKEND_GO_WORKER_GENERAL_PORT=8013
BACKEND_GO_SERVICE_PREFIX=pickletour

# backend-go reads Mongo URI the same way as the Node backend:
# NODE_ENV=production -> MONGO_URI_PROD
# otherwise -> MONGO_URI
NODE_ENV=development
MONGO_URI=
MONGO_URI_PROD=

# Required for admin JWT verification
JWT_SECRET=

# Optional when the Mongo URI does not encode a database name
MONGO_DB_NAME=
REDIS_URL=redis://127.0.0.1:6379/0

# Optional overrides
PROJECT_ROOT=
UPLOADS_DIR=

# Optional live-recording playback settings reused by recordings v2 read routes
LIVE_RECORDING_PLAYBACK_BASE_URL=
LIVE_MULTI_SOURCE_ENABLED=false
LIVE_SERVER2_DELAY_SECONDS=60
LIVE_RECORDING_PUBLIC_CDN_BASE_URL=
LIVE_SERVER2_MANIFEST_NAME=live-manifest.json
R2_RECORDINGS_TARGETS_JSON=
GRAPHQL_DEPRECATION_MODE=audit

# Optional dedicated Mongo URI for integration tests
BACKEND_GO_TEST_MONGO_URI=
